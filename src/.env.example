# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# GitLab Configuration (choose GitLab OR GitHub)
GITLAB_TOKEN=your_gitlab_access_token
GITLAB_URL=https://gitlab.com  # or your self-hosted GitLab URL
GITLAB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Configuration (alternative to GitLab)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Platform Selection
PLATFORM=github  # or "github"

# Agent Configuration
AGENT_NAME=AH-Reviewer-Bot
MAX_FILES_TO_REVIEW=10
MAX_DIFF_LINES=500

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
