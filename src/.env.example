# ============================================================
# Local .env for running the Action image outside GitHub.
# Production usage is via action.yml `inputs:` in a workflow file.
# ============================================================

# ------------------------------------------------------------
# LLM provider — choose ONE
# ------------------------------------------------------------

# Default: OpenAI
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4o-mini   # optional; default shown

# Alternative: Moonshot / Kimi
# LLM_PROVIDER=kimi
# MOONSHOT_API_KEY=your_moonshot_api_key_here
# LLM_MODEL=kimi-k2-0905-preview   # optional; default shown

# Optional: override the API base URL (e.g. self-hosted proxy, or a newer Kimi model ID).
# LLM_BASE_URL=https://api.moonshot.ai/v1

# ------------------------------------------------------------
# GitHub — the Action receives this via ${{ secrets.GITHUB_TOKEN }}.
# For local smoke-tests, provide a Personal Access Token with
# `pull_request:write` (classic) or `pull-requests: write` (fine-grained).
# ------------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token

# ------------------------------------------------------------
# Agent behavior
# ------------------------------------------------------------
AGENT_NAME=PR-Reviewer-Bot
MAX_FILES_TO_REVIEW=10
MAX_DIFF_LINES=500

# Kill switch. Set to "false" to acknowledge events without calling the LLM
# (useful during incidents or cost spikes).
REVIEW_ENABLED=true

# ------------------------------------------------------------
# Local smoke-test fallbacks. Used only when GITHUB_EVENT_PATH is
# unset (i.e. you're running `python -m src.action` manually).
# ------------------------------------------------------------
# CLI_REPO=octocat/hello-world
# CLI_PR=1
# CLI_SHA=abc123def4567890
